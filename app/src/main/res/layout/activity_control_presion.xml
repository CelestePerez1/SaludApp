<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FFFFFF"
    tools:context=".ControlPresion">

    <!-- Toolbar morado -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="#007B2FBE"
        android:gravity="center_horizontal|center_vertical"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="16dp">

        <TextView
            style="@style/TitleTextStyle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="  Registro de Presión Arterial"

            android:textSize="17sp"
            android:textStyle="bold" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#FFFFFF">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingTop="16dp"
            android:paddingBottom="24dp">

            <!-- Botón seleccionar fecha -->
            <Button
                android:id="@+id/btnFecha"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginBottom="8dp"
                android:backgroundTint="#1A4375"
                android:text="Seleccionar fecha"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"
                app:cornerRadius="8dp" />

            <!-- Fecha seleccionada -->
            <TextView
                android:id="@+id/txtFecha"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Fecha no seleccionada"
                android:textColor="#212121"
                android:textSize="15sp"
                android:layout_marginBottom="4dp" />

            <!-- Hora de la medición -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Hora de la medición"
                android:textColor="#212121"
                android:textSize="15sp"
                android:layout_marginBottom="4dp" />

            <TimePicker
                android:id="@+id/timePicker"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginBottom="8dp"
                android:numbersSelectorColor="#090808"
                android:numbersTextColor="#212121"
                android:timePickerMode="spinner" />

            <!-- Valores de la medición -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Valores de la medición"
                android:textColor="#212121"
                android:textSize="15sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">

                <!-- Sistólica -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Sistólica"
                        android:textColor="#212121"
                        android:textSize="13sp" />

                    <NumberPicker
                        android:id="@+id/npSistolica"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />
                </LinearLayout>

                <!-- Diastólica -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Diastólica"
                        android:textColor="#212121"
                        android:textSize="13sp" />

                    <NumberPicker
                        android:id="@+id/npDiastolica"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />
                </LinearLayout>

                <!-- Pulso -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Pulso"
                        android:textColor="#212121"
                        android:textSize="13sp" />

                    <NumberPicker
                        android:id="@+id/npPulso"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />
                </LinearLayout>
            </LinearLayout>

            <!-- Brazo utilizado -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Brazo utilizado"
                android:textColor="#212121"
                android:textSize="15sp"
                android:textStyle="bold"
                android:layout_marginBottom="4dp" />

            <RadioGroup
                android:id="@+id/rgBrazo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="16dp">

                <RadioButton
                    android:id="@+id/rbIzquierdo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Brazo izquierdo"
                    android:textColor="#212121"
                    android:buttonTint="#7B2FBE" />

                <RadioButton
                    android:id="@+id/rbDerecho"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Brazo derecho"
                    android:textColor="#212121"
                    android:buttonTint="#7B2FBE" />
            </RadioGroup>

            <!-- Botón Analizar -->
            <Button
                android:id="@+id/btnAnalizar"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginBottom="16dp"
                android:backgroundTint="#1A4375"
                android:text="Analizar medición"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"
                app:cornerRadius="8dp" />

            <!-- Resumen de la medición -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Resumen de la medición"
                android:textColor="#212121"
                android:textSize="15sp"
                android:textStyle="bold"
                android:layout_marginBottom="6dp" />

            <!-- Resultado texto -->
            <TextView
                android:id="@+id/txtResultado"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="14sp"
                android:textColor="#424242"
                android:lineSpacingExtra="4dp"
                android:layout_marginBottom="8dp" />

            <!-- Fila clasificación (oculta al inicio) -->
            <LinearLayout
                android:id="@+id/layoutClasificacion"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Clasificación: "
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#212121" />

                <TextView
                    android:id="@+id/txtClasificacion"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="4dp" />
            </LinearLayout>

            <!-- Consejo de salud (oculto al inicio) -->
            <LinearLayout
                android:id="@+id/layoutConsejo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="#F3E5F5"
                android:padding="10dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ℹ️  "
                    android:textSize="16sp" />

                <TextView
                    android:id="@+id/txtConsejo"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textSize="13sp"
                    android:textColor="#616161" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>
</LinearLayout>
