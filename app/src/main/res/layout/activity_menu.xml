<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#E4EEF7"
    tools:context=".Menu">

    <ImageView
        android:id="@+id/logoSaludApp"
        android:layout_width="0dp"
        android:layout_height="120dp"
        android:layout_marginTop="24dp"
        android:scaleType="centerInside"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:srcCompat="@drawable/saludapplogo" />

    <androidx.gridlayout.widget.GridLayout
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"

        android:paddingLeft="4dp"
        android:paddingRight="7dp"
        app:columnCount="2"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/logoSaludApp"
        app:rowCount="3">

        <androidx.cardview.widget.CardView
            android:id="@+id/cardPeso"
            style="@style/SaludCardStyle"
            android:layout_width="186dp"

            android:layout_height="175dp"
            app:cardBackgroundColor="#FFFEFE"
            app:layout_column="0"
            app:layout_row="0">

            <LinearLayout
                style="@style/SaludCardContentStyle"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical">

                <ImageView
                    android:id="@+id/imageView3"
                    android:layout_width="60dp"
                    android:layout_height="60dp"
                    app:srcCompat="@drawable/ic_peso" />

                <TextView
                    android:id="@+id/textView"
                    style="@style/TitleTextStyle"
                    android:text="Seguimiento \n Integral del peso" />

                <TextView
                    android:id="@+id/textView2"
                    style="@style/SubtitleTextStyle"
                    android:text="Registro, IMC, meta y proceso" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:id="@+id/cardPresion"
            style="@style/SaludCardStyle"
            android:layout_width="186dp"

            android:layout_height="175dp"
            app:cardBackgroundColor="#FFFEFE"
            app:layout_column="1"
            app:layout_row="0">

            <LinearLayout
                style="@style/SaludCardContentStyle"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical">

                <ImageView
                    android:id="@+id/imageView5"
                    android:layout_width="60dp"
                    android:layout_height="60dp"
                    app:srcCompat="@drawable/ic_presion" />

                <TextView
                    android:id="@+id/textView6"
                    style="@style/TitleTextStyle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="Control de presión \n  arterial" />

                <TextView
                    android:id="@+id/textView5"
                    style="@style/SubtitleTextStyle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_horizontal"
                    android:text="Registrar sistolica, n astolica e historial" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:id="@+id/cardGlucosa"
            style="@style/SaludCardStyle"
            android:layout_width="186dp"

            android:layout_height="175dp"
            app:cardBackgroundColor="#FFFEFE"
            app:layout_column="0"


            app:layout_row="1">

            <LinearLayout
                style="@style/SaludCardContentStyle"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical">

                <ImageView
                    android:id="@+id/imageView6"
                    android:layout_width="60dp"
                    android:layout_height="60dp"
                    app:srcCompat="@drawable/ic_glucosa" />

                <TextView
                    android:id="@+id/textView7"
                    style="@style/TitleTextStyle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Control de glucosa" />

                <TextView
                    android:id="@+id/textView10"
                    style="@style/SubtitleTextStyle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Niveles en sangre y registros por fecha" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:id="@+id/cardActividad"
            style="@style/SaludCardStyle"
            android:layout_width="186dp"

            android:layout_height="175dp"
            app:cardBackgroundColor="#FFFEFE"
            app:layout_column="1"
            app:layout_row="1">

            <LinearLayout
                style="@style/SaludCardContentStyle"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical">

                <ImageView
                    android:id="@+id/imageView7"
                    android:layout_width="60dp"
                    android:layout_height="60dp"
                    app:srcCompat="@drawable/ic_actividad" />

                <TextView
                    android:id="@+id/textView12"
                    style="@style/TitleTextStyle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Control de Actividad \n fisica" />

                <TextView
                    android:id="@+id/textView11"
                    style="@style/SubtitleTextStyle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tipos, duración y \n habitos saludables" />
            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:id="@+id/cardHidra"
            style="@style/SaludCardStyle"
            android:layout_width="186dp"

            android:layout_height="175dp"
            app:cardBackgroundColor="#FFFEFE"
            app:layout_column="0"
            app:layout_row="2">

            <LinearLayout
                style="@style/SaludCardContentStyle"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical">

                <ImageView
                    android:id="@+id/imageView8"
                    android:layout_width="60dp"
                    android:layout_height="60dp"
                    app:srcCompat="@drawable/ic_agua" />

                <TextView
                    android:id="@+id/textView13"
                    style="@style/TitleTextStyle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Control de hidratacion" />

                <TextView
                    android:id="@+id/textView14"
                    style="@style/SubtitleTextStyle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Consumo Diario y \n progreso" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:id="@+id/cardMedica"
            style="@style/SaludCardStyle"
            android:layout_width="186dp"

            android:layout_height="175dp"
            app:cardBackgroundColor="#FFFEFE"
            app:layout_column="1"
            app:layout_row="2">

            <LinearLayout
                style="@style/SaludCardContentStyle"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical">

                <ImageView
                    android:id="@+id/imageView9"
                    android:layout_width="60dp"
                    android:layout_height="60dp"
                    app:srcCompat="@drawable/ic_medicina" />

                <TextView
                    android:id="@+id/textView15"
                    style="@style/TitleTextStyle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Medicamentos/ Recordatorios" />

                <TextView
                    android:id="@+id/textView16"
                    style="@style/SubtitleTextStyle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Horarios y organizacion personal" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </androidx.gridlayout.widget.GridLayout>
</androidx.constraintlayout.widget.ConstraintLayout>